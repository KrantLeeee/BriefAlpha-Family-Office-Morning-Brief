# Backend
BRIEFALPHA_ENV=development

# Mode: "demo" (default; serves fixture, no external API calls) or
# "live" (real ingestion + LLM pipeline). Live mode fail-fasts on
# startup if required keys are missing — see README "切换模式".
BRIEFALPHA_MODE=demo

# Required for live mode (SEC RSS rejects requests without it):
# SEC_EDGAR_USER_AGENT="BriefAlpha/dev your.email@example.com"

BRIEFALPHA_BRIEF_TIMEZONE=Asia/Hong_Kong
BRIEFALPHA_BRIEF_DELIVERY_TIME=08:30
BRIEFALPHA_AUDIT_MODE=demo
BRIEFALPHA_LLM_PROVIDER=openai
BRIEFALPHA_REDIS_URL=redis://localhost:6379/0
BRIEFALPHA_DB_URL=sqlite+aiosqlite:///./data/briefalpha.db
# BRIEFALPHA_DISABLE_REDIS=1
# BRIEFALPHA_DISABLE_SCHEDULER=1

# LLM keys are normally stored in data/.secrets/llm_api_keys.json:
# {
#   "anthropic": "replace-me",
#   "openai": "sk-...",
#   "vision_openai": "sk-...",
#   "vision_anthropic": "replace-me"
# }
#
# Environment variable fallback is also supported by the provider wrapper:
# OPENAI_API_KEY=sk-...
# VISION_OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# VISION_ANTHROPIC_API_KEY=sk-ant-...

# Optional market/news provider keys.
# Current MVP code uses keyless sources by default:
# - yfinance
# - GDELT
# - Google News RSS
# - SEC EDGAR RSS
# - HKEX RSS
#
# These are placeholders for enabling paid/keyed adapters later; the current
# adapter code does not read them yet.
# FINNHUB_API_KEY=
# ALPHA_VANTAGE_API_KEY=
# NEWSAPI_KEY=
# FRED_API_KEY=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
