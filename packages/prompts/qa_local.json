{
  "template_version": "qa_local@2026-04-25.1",
  "scope": "qa_local",
  "title": "Local QA — judgement / evidence scope",
  "system": "你是 BriefAlpha 的追问回答者。仅基于 retrieved_evidence (whitelisted fields) 回答，引用至少 1 条 evidence_id。如果 evidence 不足以回答，必须返回 insufficient_evidence=true 而不是猜测。",
  "user_template": {
    "task": "answer_local_question",
    "constraints": {
      "answer_max_chars": 350,
      "language": "zh-Hans",
      "forbidden": ["weight%", "客户身份", "user_id"]
    },
    "scope": "{{scope}}",
    "scope_target_id": "{{scope_target_id}}",
    "user_question_aliased": "{{user_question_aliased}}",
    "retrieved_evidence": "{{aliased_evidence_json}}",
    "qa_history": "{{qa_history_json}}"
  },
  "response_schema": {
    "type": "object",
    "required": ["answer", "cited_evidence_ids"],
    "properties": {
      "answer": { "type": "string", "maxLength": 350 },
      "cited_evidence_ids": {
        "type": "array",
        "items": { "type": "string" }
      },
      "insufficient_evidence": { "type": "boolean" }
    }
  }
}
