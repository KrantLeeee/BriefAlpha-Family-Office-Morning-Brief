{
  "template_version": "stage_b@2026-04-25.1",
  "scope": "stage_b",
  "title": "1-5 judgements with reasoning_chain",
  "system": "你是 BriefAlpha 的研判生成器。每个 judgement 必须包含四层 reasoning_chain（observed / portfolio_exposure / inference / conclusion），引用至少 2 条 evidence_id。",
  "user_template": {
    "task": "generate_judgements",
    "constraints": {
      "min_judgements": 1,
      "max_judgements": 5,
      "judgement_title_max_chars": 60,
      "evidence_summary_max_chars": 120,
      "min_citations_per_judgement": 2,
      "language": "zh-Hans",
      "forbidden": ["weight%", "specific_ticker_weight", "user PII", "sector_bucket"]
    },
    "evidence": "{{aliased_evidence_json}}",
    "portfolio_context": {
      "no_direct_portfolio_link": "{{no_direct_portfolio_link}}",
      "asset_class_summary_only": true
    }
  },
  "response_schema": {
    "type": "object",
    "required": ["judgements"],
    "properties": {
      "judgements": {
        "type": "array",
        "minItems": 1,
        "maxItems": 5,
        "items": {
          "type": "object",
          "required": ["rank", "level", "title", "reasoning_chain", "cited_evidence_ids"],
          "properties": {
            "rank": { "type": "integer", "minimum": 1, "maximum": 5 },
            "level": { "type": "string", "enum": ["elevated", "watch", "info"] },
            "title": { "type": "string", "maxLength": 60 },
            "reasoning_chain": {
              "type": "object",
              "required": ["observed", "portfolio_exposure", "inference", "conclusion"],
              "properties": {
                "observed": { "type": "string", "maxLength": 200 },
                "portfolio_exposure": { "type": "string", "maxLength": 200 },
                "inference": { "type": "string", "maxLength": 200 },
                "conclusion": { "type": "string", "maxLength": 200 }
              }
            },
            "cited_evidence_ids": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 2
            },
            "no_direct_portfolio_link": { "type": "boolean" },
            "requires_review": { "type": "boolean" }
          }
        }
      }
    }
  }
}
